"use client";

import { Canvas, useFrame } from '@react-three/fiber';
import { OrbitControls, Float, Text, Sparkles } from '@react-three/drei';
import { EffectComposer, Bloom } from '@react-three/postprocessing';
import { motion } from 'framer-motion';
import { useRef } from 'react';
import * as THREE from 'three';

function HouseModel({ onClick }: { onClick: () => void }) {
  const meshRef = useRef<THREE.Mesh>(null);
  
  useFrame((state) => {
    meshRef.current!.rotation.y = Math.sin(state.clock.elapsedTime * 0.5) * 0.1;
    meshRef.current!.position.y = Math.sin(state.clock.elapsedTime * 2) * 0.02;
  });

  return (
    <Float rotationIntensity={0.3} floatIntensity={0.8}>
      <mesh ref={meshRef} onClick={onClick}>
        <boxGeometry args={[1.5, 1.2, 1]} />
        <meshStandardMaterial 
          color="#4f46e5" 
          metalness={0.3}
          roughness={0.2}
          envMapIntensity={1}
        />
        <Sparkles count={50} scale={2} speed={0.5} />
      </mesh>
      
      {/* Roof */}
      <mesh position={[0, 0.8, 0]} rotation={[-Math.PI * 0.4, 0, 0]}>
        <coneGeometry args={[1.2, 0.6, 4]} />
        <meshStandardMaterial color="#ef4444" metalness={0.4} />
      </mesh>
    </Float>
  );
}

export function ThreeDProperty() {
  const [selectedRoom, setSelectedRoom] = useState<'kitchen' | 'living' | 'bathroom'>('living');

  return (
    <div className="w-full h-full rounded-xl overflow-hidden border-2 border-white/30">
      <Canvas
        camera={{ position: [3, 2, 5], fov: 50 }}
        gl={{ antialias: true, powerPreference: "high-performance" }}
      >
        <ambientLight intensity={0.6} />
        <directionalLight position={[10, 10, 5]} intensity={1} />
        <pointLight position={[-10, -10, -10]} color="#4f46e5" intensity={0.5} />
        
        <HouseModel onClick={() => console.log('3D house clicked')} />
        
        <OrbitControls 
          enablePan={false}
          enableZoom={true}
