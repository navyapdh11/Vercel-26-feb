        />
        
        <EffectComposer>
          <Bloom luminanceThreshold={0.3} luminanceSmoothing={0.9} height={300} />
        </EffectComposer>
      </Canvas>
      
      {/* Room Selector */}
      <div className="absolute bottom-4 left-4 right-4 bg-black/50 backdrop-blur-xl rounded-xl p-3">
